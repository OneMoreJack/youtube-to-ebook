# YouTube to Ebook - Environment Variables
# Copy this file to .env and fill in your keys

# YouTube Data API Key (free from Google Cloud Console)
# Get it at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Anthropic API Key (for Claude)
# Get it at: https://console.anthropic.com/

# 中国大陆用户可在这里获取 API key：
# https://cc.honoursoft.cn/register?aff=dlK9 (我的邀请链接)
# 如果你有官方的 API key，可以删除 ANTHROPIC_BASE_URL
# 如果你使用其他代理，请修改 ANTHROPIC_BASE_URL
ANTHROPIC_BASE_URL=https://cc.honoursoft.cn
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gmail credentials (optional - for email delivery)
# Create an App Password at: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here
